Bootstrap: docker
From: python:3.13-slim
Stage: build

%files
    ../GAME-Enformer-predictor/ /enformer_GAME

%environment
    # Prevent binding of host directories by default
    export APPTAINER_NO_MOUNT="home,tmp,proc,sys,dev"
    export LC_ALL=C
    export PATH="/opt/conda/envs/enformer17/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/conda/envs/enformer17/lib:$LD_LIBRARY_PATH"

%post
    echo "Installing system dependencies..."
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        bzip2 \
        ca-certificates \
        build-essential
    apt-get clean && rm -rf /var/lib/apt/lists/*

    echo "Setting up Miniconda..."
    mkdir -p /opt && \
    wget -q https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O /miniconda.sh && \
    bash /miniconda.sh -b -p /opt/conda && \
    rm -rf /miniconda.sh

    # Temporarily add conda to PATH for this script
    echo "Initializing Conda..."
    export PATH="/opt/conda/bin:$PATH"
    # . /opt/conda/etc/profile.d/conda.sh

    echo "Setting solver to classic and disabling plugins..."
    CONDA_NO_PLUGINS=true conda config --set solver classic

    # Create the conda environment using the correct file path
    echo "Creating Conda environment 'enformer'..."
    CONDA_NO_PLUGINS=true conda env create -n enformer17 -f /enformer_GAME/enformer_GPU.yml
    conda clean -a -y

    echo "Verifying Conda environment creation..."
    if ! conda env list | grep -q enformer17; then
        echo "Error: Conda environment 'enformer' was not created successfully."
        exit 1
    fi

    # Activate the environment for subsequent commands
    echo "Activating Conda environment..."
    . /opt/conda/etc/profile.d/conda.sh
    conda activate enformer17

    echo "Installing Flask..."
    pip install flask
    # pip install waitress

    echo "Setting permissions..."
    chmod -R 755 /opt/conda
    chmod +x /opt/conda/envs/enformer17/bin/python3
    chmod -R 755 /enformer_GAME
    echo "Cleaning up temporary files..."
    conda clean --all --yes

%runscript
    export PATH="/opt/conda/envs/enformer17/bin:$PATH"
    exec python3 /enformer_GAME/enformer_predictor_rest_api.py "$@"

%startscript
    export PATH="/opt/conda/envs/enformer17/bin:$PATH"
    exec python3 /enformer_GAME/enformer_predictor_rest_api.py "$@"

%labels
    Authors "Ishika Luthra, Satyam Priyadarshi"
    Version "1.0"
    Description "This container is the Predictor set up for Genomic API for Model Evaluation using the Enformer model."

%help
    This container for Predictor includes:
    - Predictor script for sequence processing and error handling.
    - Integrated Enformer model with its dependencies and `enformer17` conda environment created using `enformer_GPU.yml`.
    - Support scripts like `api_preprocessing_utils.py`, `error_message_functions_updated.py`, and `predictor_help_message.json`.
    
    NOTE: This container requires a GPU for execution because the Enformer model relies on GPU-accelerated operations from TensorFlow. 

    Usage:
    We encourage using pre-built containers for this model that are hosted on Zenodo. Visit https://github.com/de-Boer-Lab/Genomic-API-for-Model-Evaluation for more information.

    Run the container
    ```
    apptainer run --nv --containall predictor_enformer.sif HOST_IP HOST_PORT MATCHER_IP MATCHER_PORT
    ```

    Details
    - The container receives data via HTTP and does not require mounted data directories.
    - Replace `HOST_IP` and `PORT_IP` with the server IP and port configuration for the Evaluator to connect to.
    - Replace `MATCHER_IP` and `MATCHER_PORT` with the IP and port configuration of the Matcher for the Predictor to connect to. If Matcher is not needed for the task, put in placeholder IP and PORT.
    - The `--nv` flag sets up the environment of the container to use an NVIDIA GPU and CUDA libraries to run a CUDA-enabled application.
    - The `--containall` flag ensures a clean, isolated environment for reproducible runs.

    Purpose
    - Facilitates genomic model evaluation and prediction using the Enformer model.
    - It is designed to seamlessly integrate with other tools via API endpoints, like Matcher.

    Example Command
    ```
    apptainer run --nv --containall predictor_enformer.sif 172.xx.xx.xx 5000 192.xx.xx.xx 6000
    ```

    Arguments
    1. `HOST_IP`: IP address or hostname of the Predictor server.
    2. `PORT_IP`: Port number the Predictor is listening on.
    3. `MATCHER_IP`: IP address or the hostname of the Matcher server.
    4. `MATCHER_PORT`: Port number the Matcher is listening on.
